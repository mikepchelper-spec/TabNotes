{
  "name": "tabnotes-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TabNotes — contextual notes per tab/URL/domain/workspace",
  "scripts": {
    "dev": "pnpm --filter @tabnotes/web dev",
    "dev:web": "pnpm --filter @tabnotes/web dev",
    "build": "pnpm --filter @tabnotes/shared build && pnpm --filter @tabnotes/ui build && pnpm --filter @tabnotes/web build && pnpm --filter @tabnotes/extension build",
    "build:extension": "pnpm --filter @tabnotes/extension build",
    "build:web": "pnpm --filter @tabnotes/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\" --ignore-path .prettierignore"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
