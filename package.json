{
  "name": "tabnotes-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "TabNotes — contextual notes per tab/URL/domain/workspace",
  "scripts": {
    "dev": "pnpm --filter @tabnotes/web dev",
    "dev:web": "pnpm --filter @tabnotes/web dev",
    "build": "pnpm build:web && pnpm build:extension",
    "build:extension": "pnpm --filter @tabnotes/extension build",
    "build:web": "pnpm --filter @tabnotes/web build",
    "lint": "eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\" --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\" --ignore-path .prettierignore"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "typescript": "^5.4.5"
  }
}
